# Server
PORT=3002
HOST=0.0.0.0
LOG_LEVEL=info
NODE_ENV=development

# Policy
POLICY_DIR=./policies
POLICY_TIMEZONE=Africa/Lagos

# Anthropic — enables AI rollback analysis (optional)
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# GitHub — fine-grained token with read access to your repos
# https://github.com/settings/tokens
GITHUB_TOKEN=github_pat_...

# Kubernetes — set to true when no real cluster is available
K8S_DRY_RUN=true

# Slack — create a bot at https://api.slack.com/apps
# Required scopes: chat:write
# Enable Interactivity, set Request URL to: https://your-domain/slack/interactions
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
SLACK_APPROVAL_CHANNEL="#platform-approvals"

# Database path (defaults to ./data/control-plane.db)
# DB_PATH=/app/data/control-plane.db
